# Use Node.js LTS
FROM node:22-alpine

# Install openssh-client for key generation utilities
RUN apk add --no-cache openssh

# Set working directory
WORKDIR /app

# Copy package files
COPY package.json package-lock.json* ./

# Install dependencies
RUN npm install

# Copy application code
COPY server.js .

# Expose SSH port
EXPOSE 2222

# Set environment
ENV NODE_ENV=production

# Start the server
CMD ["node", "server.js"]